<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ffffff"
    android:padding="12dp">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <TextView
            android:id="@+id/tvHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Medical Report — Asthma"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingBottom="12dp"/>

        <!-- Clinic / Doctor info (optional) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Clinic: Al-Salam Medical Center"
            android:textSize="12sp"
            android:paddingBottom="8dp"/>

        <!-- Card-like container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#ffffff"
            android:padding="12dp"
            android:elevation="2dp">

            <!-- Row: Name + Age -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:paddingBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:orientation="vertical"
                    android:paddingEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Name"
                        android:textStyle="bold"
                        android:textSize="14sp"/>
                    <EditText
                        android:id="@+id/etName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Enter patient name"
                        android:inputType="textPersonName"
                        android:singleLine="true"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Age"
                        android:textStyle="bold"
                        android:textSize="14sp"/>
                    <EditText
                        android:id="@+id/etAge"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Age"
                        android:inputType="number"
                        android:singleLine="true"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Patient ID -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Patient ID"
                android:textStyle="bold"
                android:textSize="14sp"/>
            <EditText
                android:id="@+id/etPatientId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. 123456"
                android:inputType="text"
                android:singleLine="true"
                android:paddingBottom="8dp"/>

            <!-- Diagnosis -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Diagnosis"
                android:textStyle="bold"
                android:textSize="14sp"/>
            <EditText
                android:id="@+id/etDiagnosis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. Asthma — Moderate Persistent"
                android:inputType="textCapSentences"
                android:singleLine="false"
                android:maxLines="2"
                android:paddingBottom="8dp"/>

            <!-- Last Visit (date) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Last Visit (YYYY-MM-DD)"
                android:textStyle="bold"
                android:textSize="14sp"/>
            <EditText
                android:id="@+id/etLastVisit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="2025-10-15"
                android:inputType="date"
                android:singleLine="true"
                android:paddingBottom="8dp"/>

            <!-- Medications -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medications"
                android:textStyle="bold"
                android:textSize="14sp"/>
            <EditText
                android:id="@+id/etMedications"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="• Salbutamol Inhaler — 2 puffs prn\n• Fluticasone — 1 puff BID"
                android:inputType="textMultiLine"
                android:minLines="2"
                android:maxLines="4"
                android:paddingBottom="8dp"/>

            <!-- Doctor Notes -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Doctor Notes"
                android:textStyle="bold"
                android:textSize="14sp"/>
            <EditText
                android:id="@+id/etNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Advice, follow-up, triggers, etc."
                android:inputType="textMultiLine"
                android:minLines="3"
                android:maxLines="6"
                android:paddingBottom="12dp"/>

            <!-- Peak Flow / Measurements (optional) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Peak Flow (L/min) — Optional"
                android:textStyle="bold"
                android:textSize="14sp"/>
            <EditText
                android:id="@+id/etPeakFlow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. 420"
                android:inputType="number"
                android:singleLine="true"
                android:paddingBottom="8dp"/>
        </LinearLayout>

        <!-- Buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="12dp"
            android:weightSum="3">

            <Button
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Save"/>

            <Button
                android:id="@+id/btnClear"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Clear"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnPrint"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Print"/>
        </LinearLayout>

        <!-- Footer / Signature -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Doctor: ____________________   Signature: ________________"
                android:textSize="12sp"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
