<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F2F6FB">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Top Bar -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:padding="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Weather "
                android:layout_gravity="center"
                android:layout_marginLeft="16dp"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#000" />
        </LinearLayout>

        <!-- Weather Card -->
        <LinearLayout
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginTop="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center" />

            <TextView
                android:text="Current Weather"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Sunny"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:layout_marginTop="4dp"/>

            <!-- Grid -->
            <GridLayout
                android:rowCount="2"
                android:columnCount="2"
                android:layout_marginTop="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Temp -->
                <LinearLayout
                    android:orientation="vertical"
                    android:padding="8dp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp" />

                    <TextView
                        android:id="@+id/Temperature"
                        android:layout_marginTop="4dp"
                        android:text="Temperature"
                        android:textSize="13sp" />

                </LinearLayout>

                <!-- Humidity -->
                <LinearLayout
                    android:orientation="vertical"
                    android:padding="8dp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp" />

                    <TextView
                        android:id="@+id/Humidity"
                        android:layout_marginTop="4dp"
                        android:text="Humidity"
                        android:textSize="13sp" />

                    <TextView
                        android:text="60%"
                        android:textStyle="bold"
                        android:textSize="14sp"/>
                </LinearLayout>

                <!-- Wind -->
                <LinearLayout
                    android:orientation="vertical"
                    android:padding="8dp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp" />

                    <TextView
                        android:text="Wind Speed"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp"/>

                    <TextView
                        android:text="5 mph"
                        android:textStyle="bold"
                        android:textSize="14sp"/>
                </LinearLayout>

                <!-- Pollen -->
                <LinearLayout
                    android:orientation="vertical"
                    android:padding="8dp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp" />

                    <TextView
                        android:text="Pollen Level"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp"/>

                    <TextView
                        android:text="Low"
                        android:textStyle="bold"
                        android:textSize="14sp"/>
                </LinearLayout>

            </GridLayout>
        </LinearLayout>

        <!-- Health Advice Card -->
        <LinearLayout
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="Today's Health Advice"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:text="Sunny weather can sometimes increase pollen levels..."
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />

            <TextView
                android:text="Possible Symptoms:"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp" />

            <TextView
                android:text="• Sneezing\n• Runny nose\n• Itchy eyes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Medication Plan -->
        <LinearLayout
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="Your Medication Plan"
                android:textStyle="bold"
                android:textSize="16sp"  android:layout_height=""/>

            <TextView
                android:text="Albuterol Sulfate"
                android:textStyle="bold"
                android:layout_marginTop="12dp"
                android:textSize="15sp" />

            <TextView
                android:text="Dosage: 2 puffs"
                android:layout_marginTop="4dp" />

            <TextView
                android:text="Timing: Once in the morning"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Buttons -->
        <Button
            android:text="View Weekly Forecast"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="#8EE596"
            android:textColor="#FFF"
            android:padding="12dp" />

    </LinearLayout>

</ScrollView>
